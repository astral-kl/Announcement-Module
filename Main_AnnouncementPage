import { FileText, ThumbsUp, ThumbsDown, MoreVertical } from "lucide-react";
import { Button } from "./ui/button";

interface AnnouncementCardProps {
  title: string;
  description: string;
  publishedBy: string;
  uploadedTime: string;
  tags?: string[];
}

export function AnnouncementCard({
  title,
  description,
  publishedBy,
  uploadedTime,
  tags = ["Hot", "New", "Trending"]
}: AnnouncementCardProps) {
  return (
    <article className="bg-white rounded-lg p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      {/* Header */}
      <div className="flex items-start justify-between mb-4">
        <h3 className="text-2xl md:text-3xl font-semibold text-black">
          {title}
        </h3>
        <Button variant="ghost" size="icon" className="text-[#8e8e8e]">
          <MoreVertical className="h-5 w-5" />
        </Button>
      </div>

      {/* Document Info */}
      <div className="flex items-center gap-3 mb-4">
        <FileText className="h-8 w-8 text-black" />
        <span className="text-lg md:text-xl text-black">
          USG Financial Report.docx
        </span>
      </div>

      {/* Description */}
      <p className="text-base text-black mb-4 leading-relaxed">
        {description}
      </p>

      {/* Tags */}
      <div className="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span
            key={tag}
            className="bg-[#C8102E] text-white text-sm px-3 py-1 rounded-md"
          >
            {tag}
          </span>
        ))}
      </div>

      {/* Footer */}
      <div className="flex items-center justify-between pt-4 border-t border-gray-100">
        {/* Meta Info */}
        <div className="text-sm text-[#8e8e8e] italic">
          <p>Published By: {publishedBy}</p>
          <p>Uploaded: {uploadedTime}</p>
        </div>

        {/* Action Buttons */}
        <div className="flex items-center gap-2">
          <Button
            variant="ghost"
            size="icon"
            className="text-[#8e8e8e] hover:text-[#C8102E] hover:bg-[#C8102E]/10"
          >
            <ThumbsUp className="h-5 w-5" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            className="text-[#8e8e8e] hover:text-[#C8102E] hover:bg-[#C8102E]/10"
          >
            <ThumbsDown className="h-5 w-5" />
          </Button>
        </div>
      </div>
